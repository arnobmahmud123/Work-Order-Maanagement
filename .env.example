# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proppreserve"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# App encryption
APP_ENCRYPTION_KEY="change-this-to-a-random-32-char-string"

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# AI (optional)
# OPENAI_API_KEY=
# OPENAI_BID_MODEL=gpt-4o
